# CyberAI Live Threat Map — Backend Configuration

HOST=0.0.0.0
PORT=8000
DEBUG=false

# Attack generation interval (seconds)
SOCKET_INTERVAL=1.0

# Summary broadcast interval (seconds)
SUMMARY_INTERVAL=5.0

# Optional Redis URL for future pub/sub scaling
REDIS_URL=

# Optional PostgreSQL connection string for persistent storage
DATABASE_URL=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Attack timeline buffer size
ATTACK_BUFFER_SIZE=500

# URL Scanner — number of recent scans kept in memory for /api/url-scanner/history
URL_SCANNER_HISTORY_SIZE=200

# ---------------------------------------------------------------------------
# External threat-intel API keys
# Copy this file to backend/.env and fill in the keys you have. Services
# without a key are automatically disabled (their endpoints return 503 with a
# clear message). CISA KEV, HIBP breach catalog, PhishTank, and IPInfo work
# without keys.
# ---------------------------------------------------------------------------

# Cloudflare Radar — https://dash.cloudflare.com/profile/api-tokens (Radar read)
CLOUDFLARE_RADAR_TOKEN=

# Shodan — https://account.shodan.io/
SHODAN_API_KEY=

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# PhishTank (optional, raises rate limits) — https://phishtank.org/api_register.php
PHISHTANK_APP_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api
OTX_API_KEY=

# IPInfo (optional, raises rate limits) — https://ipinfo.io/account/token
IPINFO_TOKEN=

# Have I Been Pwned (only for per-account lookups) — https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# External intel behaviour
INTEL_HTTP_TIMEOUT=15.0
INTEL_MAX_RETRIES=3
INTEL_CACHE_TTL=300.0
INTEL_BROADCAST_INTERVAL=120.0

# ---------------------------------------------------------------------------
# AI Assistant — Cybersecurity Chatbot
# Uses an OpenAI-compatible API provider.
# ---------------------------------------------------------------------------

# Provider base URL ("openai" = https://api.openai.com/v1, or custom URL)
AI_PROVIDER=openai

# API key for the AI provider
AI_API_KEY=

# Model name (e.g. gpt-4o-mini, gpt-4o, gpt-3.5-turbo)
AI_MODEL=gpt-4o-mini
