# CyberAI Frontend — Environment Configuration

# REST API base URL (FastAPI backend)
VITE_API_BASE_URL=http://localhost:8000

# Socket.IO server URL (same host as FastAPI when using python-socketio ASGI mount)
VITE_SOCKET_URL=http://localhost:8000

# Mock data has been removed — the app always uses the live backend.
# External threat-intel API keys live in backend/.env (see backend/.env.example).

# Application display name
VITE_APP_NAME=CyberAI
